{
  "schema_version": 1,
  "catalog_implementation": "nautilus_trader.persistence.catalog.ParquetDataCatalog",
  "catalog_root": "build/evidence/catalog",
  "raw_root": "build/evidence/raw",
  "report_root": "build/evidence/reports",
  "retention": "OWNER_EXPLICIT_DELETE_ONLY",
  "delete_gate": "EVIDENCE_ID_AND_CURRENT_MANIFEST_DIGEST",
  "export_format": "ZIP_RAW_MANIFEST_CHECKSUM",
  "rebuild_rule": "CATALOG_ONLY_FROM_DIGEST_VERIFIED_RAW_INPUT",
  "exit_rule": "RAW_INPUT_MANIFEST_CHECKSUM_AND_REPORT_REMAIN_READABLE_WITHOUT_HALPHA_OR_POSTGRESQL"
}
